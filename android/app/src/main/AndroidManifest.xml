<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mreader">

    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="${usesCleartextTraffic}"
        android:supportsRtl="true">

        <!-- Native Android Activities -->
        <activity
            android:name=".LG.PageActivity.ImageActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />

        <activity
            android:name=".LG.PageActivity.WebActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />


        <!-- Main Native Android Activity (Launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- React Native Activity -->
        <activity
            android:name=".LG.ReactNative.ReactNativeActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name=".LG.ReactNative.PageActivity.HistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".LG.ReactNative.PageActivity.BookmarkActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".LG.ReactNative.PageActivity.SettingActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>
        <activity
            android:name=".LG.ReactNative.PageActivity.LibraryActivity"
            android:exported="false"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>


    </application>

</manifest>
