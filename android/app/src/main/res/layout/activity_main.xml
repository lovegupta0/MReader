<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/search_bar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/top_bar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_search" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchURL"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:hint="@string/Hint"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollHorizontally="true"
                    android:singleLine="true" />

                <ImageButton
                    android:id="@+id/goUrl"
                    android:layout_width="50dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="@string/Hint"
                    android:src="@drawable/ic_goto" />
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_above="@+id/bottom_nav">

            <FrameLayout
                android:id="@+id/frame"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Menu Overlay Container -->
            <FrameLayout
                android:id="@+id/menu_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/dim_background"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/popup_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"/>

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_bottom_nav_glass"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="5dp"
            android:paddingEnd="8dp"
            android:paddingBottom="5dp">

            <ImageButton
                android:id="@+id/prev"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_bottom_nav_item"
                android:contentDescription="@string/back"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_prev"
                android:tint="#111827" />
            <ImageButton
                android:id="@+id/next"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_bottom_nav_item"
                android:contentDescription="@string/forward"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_next"
                android:tint="#111827" />
            <ImageButton
                android:id="@+id/home"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_bottom_nav_item_active"
                android:contentDescription="@string/Home"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_home"
                android:tint="#4338CA" />
            <ImageButton
                android:id="@+id/menu"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_bottom_nav_item"
                android:contentDescription="@string/Menu"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_menu"
                android:tint="#111827" />
        </LinearLayout>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
